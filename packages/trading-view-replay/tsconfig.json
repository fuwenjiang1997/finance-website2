{
  "extends": "../../tsconfig.base.json", // 继承根配置
  "compilerOptions": {
    "outDir": "dist", // 输出目录
    "declaration": true, // 生成 .d.ts 文件
    "declarationMap": true, // 生成 .d.ts.map 文件，方便调试
    "sourceMap": true, // 生成 .js.map 文件
    "jsx": "react-jsx", // 支持 React JSX
  },
  "include": ["src"], // 只编译 src 目录下的文件
  "exclude": ["node_modules", "dist"]
}